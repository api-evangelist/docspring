{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/docspring/main/json-schema/combined_submission_action.json",
  "title": "combined_submission_action",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "nullable": true
    },
    "integration_id": {
      "type": "string",
      "nullable": true
    },
    "state": {
      "type": "string",
      "enum": [
        "pending",
        "processed",
        "failed",
        "error"
      ]
    },
    "action_type": {
      "type": "string",
      "enum": [
        "webhook",
        "slack_webhook",
        "email",
        "aws_s3_upload"
      ],
      "nullable": true
    },
    "action_category": {
      "type": "string",
      "enum": [
        "notification",
        "file_upload"
      ]
    },
    "result_data": {
      "type": "object"
    },
    "error_message": {
      "type": "string",
      "nullable": true
    }
  },
  "required": [
    "action_category",
    "action_type",
    "error_message",
    "id",
    "integration_id",
    "result_data",
    "state"
  ],
  "additionalProperties": false
}