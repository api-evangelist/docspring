{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/docspring/main/json-schema/template_publish_version_response.json",
  "title": "template_publish_version_response",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "nullable": true
        },
        "published_by_id": {
          "type": "string"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "version",
        "published_by_id",
        "published_at"
      ]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "status",
    "result"
  ],
  "additionalProperties": false
}